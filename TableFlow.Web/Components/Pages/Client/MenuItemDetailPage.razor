@page "/menu/item/{Id:int}"
@using TableFlow.Web.Models
@using TableFlow.Web.Services
@using Microsoft.AspNetCore.Components.Sections
@inject CartService CartService
@inject MenuApiService MenuApiService
@inject SessionApiService SessionApiService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@layout EmptyLayout
@attribute [AllowAnonymous]
@implements IDisposable

<PageTitle>@(_item?.ItemName ?? "Loading...") — TableFlow</PageTitle>

<style>
    .add-cta {
        margin-top: 16px;
    }
    @@media (max-width: 599px) {
        .add-cta {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            padding: 12px 16px 20px;
            background: white;
            box-shadow: 0 -4px 16px rgba(0, 0, 0, 0.08);
            z-index: 100;
            margin-top: 0;
        }
        .detail-body {
            padding-bottom: 90px;
        }
    }
</style>
@* Cart icon in the app bar — only when session is active *@
@if (_state == MenuSessionState.Active)
{
    <SectionContent SectionName="client-cart-tool">
        <div style="position:relative; display:inline-flex; align-items:center; justify-content:center;">
            <MudIconButton Icon="@Icons.Material.Filled.ShoppingCart"
                           Style="color:white;"
                           Title="View cart"
                           OnClick="OpenCart" />
            @if (CartService.TotalCount > 0)
            {
                <div style="position:absolute; top:6px; right:6px;
                    background:#EF4444; color:white; border-radius:50%;
                    min-width:16px; height:16px; padding:0 3px;
                    display:flex; align-items:center; justify-content:center;
                    font-size:9px; font-weight:700; pointer-events:none; line-height:1;">
                    @CartService.TotalCount
                </div>
            }
        </div>
    </SectionContent>
}

@if (_state == MenuSessionState.Loading)
{
    <div style="max-width:600px; margin:0 auto; padding:32px 16px; text-align:center;">
        <MudProgressCircular Indeterminate="true" Size="Size.Large"
                             Style="color:var(--mud-palette-primary);" />
    </div>
}
else if (_state == MenuSessionState.InvalidToken)
{
    <div style="max-width:600px; margin:0 auto; padding:32px 16px; text-align:center;">
        <MudIcon Icon="@Icons.Material.Filled.QrCodeScanner" Style="font-size:4rem;" Class="mb-4" />
        <MudText Typo="Typo.h6">Please scan the QR code at your table to view the menu.</MudText>
    </div>
}
else if (_state == MenuSessionState.Waiting)
{
    <div style="max-width:600px; margin:0 auto; padding:32px 16px; text-align:center;">
        <MudProgressCircular Indeterminate="true" Size="Size.Large"
                             Style="color:var(--mud-palette-primary);" Class="mb-4" />
        <MudText Typo="Typo.h6">Table @_tableNumber</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Your table is being set up. Please wait a moment…
        </MudText>
    </div>
}
else if (_state == MenuSessionState.Ended)
{
    <div style="max-width:600px; margin:0 auto; padding:32px 16px; text-align:center;">
        <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Style="font-size:4rem;" Class="mb-4" />
        <MudText Typo="Typo.h6">This session has ended</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Thank you! Please ask a staff member if you need anything else.
        </MudText>
    </div>
}
else
{
    <div style="max-width:600px; margin:0 auto; padding:16px; box-sizing:border-box; width:100%;">

        @* Back Button *@
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
                   Variant="Variant.Text"
                   Color="Color.Primary"
                   Class="mb-4"
                   OnClick="@(() => Navigation.NavigateTo($"/menu?t={TableToken}"))">
            Back to Menu
        </MudButton>

        @if (_loading)
        {
            @* Loading Skeleton *@
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="260px" Width="100%" Style="border-radius:12px;" Class="mb-4" />
            <MudSkeleton Width="60%" Height="32px" Class="mb-2" />
            <MudSkeleton Width="30%" Height="24px" Class="mb-4" />
            <MudSkeleton Width="100%" Height="56px" Class="mb-2" />
            <MudSkeleton Width="100%" Height="56px" Class="mb-2" />
        }
        else if (_item is null)
        {
            <MudAlert Severity="MudBlazor.Severity.Error">Item not found or failed to load. ID: @Id</MudAlert>
        }
        else
        {
            <div class="detail-body">
            @* Hero Image — contain so no cropping regardless of image dimensions *@
            <div style="width:100%; height:260px; background:#F1F5F9; border-radius:12px;
                        display:flex; align-items:center; justify-content:center;
                        overflow:hidden; position:relative;" class="mb-4">
                @if (string.IsNullOrEmpty(_item.ImageUrl) || _imageError)
                {
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        <MudIcon Icon="@Icons.Material.Filled.Restaurant"
                                 Style="font-size:4rem; color:#CBD5E1;" />
                    </MudStack>
                }
                else
                {
                    @if (!_imageLoaded)
                    {
                        <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                                     Width="100%" Height="260px"
                                     Style="position:absolute; top:0; left:0;" />
                    }
                    <img src="@_item.ImageUrl"
                         alt="@_item.ItemName"
                         style="max-width:100%; max-height:260px; object-fit:contain; display:@(_imageLoaded ? "block" : "none");"
                         @onload="@(() => { _imageLoaded = true; StateHasChanged(); })"
                         @onerror="@(() => { _imageError = true; _imageLoaded = true; StateHasChanged(); })" />
                }
            </div>

            @* Item Info *@
            <MudText Typo="Typo.h5" Style="font-weight:700;" Class="mt-4 mb-1">@_item.ItemName</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-1">@_item.CategoryName</MudText>

            @if (!_item.IsEffectivelyAvailable)
            {
                <MudChip T="string" Color="Color.Error" Size="Size.Small" Class="mb-4">
                    Currently Unavailable
                </MudChip>
            }

            @* Variant Picker *@
            <MudText Typo="Typo.h6" Style="font-weight:600;" Class="mt-4 mb-2">Choose your option</MudText>

            @foreach (var variant in _item.Varients.Where(v => v.IsAvailable).OrderBy(v => v.Price))
            {
                var isSelected = _selectedVariant?.Id == variant.Id;
                <MudPaper Elevation="@(isSelected ? 4 : 1)"
                          Class="pa-3 mb-2"
                          Style="@GetVariantStyle(isSelected)"
                          @onclick="@(() => SelectVariant(variant))">
                    <div style="display:flex; justify-content:space-between; align-items:center;">
                        <div>
                            <MudText Typo="Typo.body1" Style="font-weight:600;">@variant.VarientName</MudText>
                        </div>
                        <div style="display:flex; align-items:center; gap:8px;">
                            <MudText Typo="Typo.body1" Color="Color.Primary" Style="font-weight:700;">
                                $@variant.Price.ToString("0.00")
                            </MudText>
                            @if (isSelected)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" />
                            }
                        </div>
                    </div>
                </MudPaper>
            }

            @if (_item.Varients.Any(v => !v.IsAvailable))
            {
                @foreach (var variant in _item.Varients.Where(v => !v.IsAvailable).OrderBy(v => v.Price))
                {
                    <MudPaper Elevation="0"
                              Class="pa-3 mb-2"
                              Style="cursor:not-allowed; border-radius:10px; opacity:0.5;">
                        <div style="display:flex; justify-content:space-between; align-items:center;">
                            <MudText Typo="Typo.body1">@variant.VarientName</MudText>
                            <div style="display:flex; align-items:center; gap:8px;">
                                <MudText Typo="Typo.body1">$@variant.Price.ToString("0.00")</MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Error">Unavailable</MudChip>
                            </div>
                        </div>
                    </MudPaper>
                }
            }

            </div> @* end detail-body *@

            <div class="add-cta">
                @if (_selectedVariant == null || !_item.IsEffectivelyAvailable)
                {
                    <div style="background:#E2E8F0; border-radius:8px; padding:15px 16px;
                                text-align:center; cursor:default; user-select:none;">
                        <span style="color:#64748B; font-weight:600; font-size:0.9375rem;">
                            @(!_item.IsEffectivelyAvailable ? "This item is currently unavailable" : "Select an option above to continue")
                        </span>
                    </div>
                }
                else
                {
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               FullWidth="true"
                               Size="Size.Large"
                               StartIcon="@Icons.Material.Filled.AddShoppingCart"
                               OnClick="AddToCart">
                        Add to Cart — $@_selectedVariant.Price.ToString("0.00")
                    </MudButton>
                }
            </div>
        }
        @* Cart Drawer *@
        <CartDrawer @ref="_cartDrawer"
                    @bind-Open="_cartOpen"
                    SessionId="@(_resolvedSessionId ?? 0)"
                    OnOrderPlaced="OnOrderPlaced" />

    </div>
}



@code {
    [Parameter] public int Id { get; set; }

    private MenuItemModel? _item;
    private bool _loading = true;
    private bool _imageLoaded = false;
    private bool _imageError = false;
    private CartDrawer _cartDrawer = null!;
    private int _quantity = 1;
    private VarientModel? _selectedVariant = null;
    private bool _cartOpen = false;

    private MenuSessionState _state = MenuSessionState.Loading;
    private int _tableNumber;
    private int? _resolvedSessionId;
    private System.Threading.Timer? _waitTimer;
    private System.Threading.Timer? _validityTimer;

    protected override void OnInitialized()
    {
        CartService.OnCartChanged += OnCartChanged;
    }

    private void OnCartChanged() => InvokeAsync(StateHasChanged);

    [SupplyParameterFromQuery(Name = "t")]
    public Guid? TableToken { get; set; }


    protected override async Task OnInitializedAsync()
    {
        if (TableToken is null || TableToken == Guid.Empty)
        {
            _state = MenuSessionState.InvalidToken;
            return;
        }

        var resolved = await SessionApiService.ResolveTableTokenAsync(TableToken.Value);
        if (resolved is null)
        {
            _state = MenuSessionState.InvalidToken;
            return;
        }

        _tableNumber = resolved.TableNumber;

        if (resolved.IsOpen && resolved.SessionId is int sessionId)
            await ActivateSessionAsync(sessionId);
        else
            EnterWaitingState();
    }

    // Open session found — load the item and watch for the session closing.
    private async Task ActivateSessionAsync(int sessionId)
    {
        _resolvedSessionId = sessionId;
        _loading = true;
        _state = MenuSessionState.Active;
        StateHasChanged();

        _item = await MenuApiService.GetMenuItemByIdAsync(Id);
        _loading = false;

        StartValidityPolling();
        StateHasChanged();
    }

    // No open session yet — poll until the cashier opens one, then activate.
    private void EnterWaitingState()
    {
        _state = MenuSessionState.Waiting;
        _waitTimer?.Dispose();
        _waitTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                var resolved = await SessionApiService.ResolveTableTokenAsync(TableToken!.Value);
                if (resolved is null)
                {
                    _waitTimer?.Dispose();
                    _waitTimer = null;
                    _state = MenuSessionState.InvalidToken;
                    StateHasChanged();
                    return;
                }

                _tableNumber = resolved.TableNumber;
                if (resolved.IsOpen && resolved.SessionId is int sessionId)
                {
                    _waitTimer?.Dispose();
                    _waitTimer = null;
                    await ActivateSessionAsync(sessionId);
                }
            });
        }, null, TimeSpan.FromSeconds(5), TimeSpan.FromSeconds(5));
    }

    // Detect the cashier closing the session while browsing → "ended" screen.
    private void StartValidityPolling()
    {
        _validityTimer?.Dispose();
        _validityTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                if (_resolvedSessionId is not int sessionId) return;
                var stillOpen = await SessionApiService.IsSessionActiveAsync(sessionId);
                if (!stillOpen)
                {
                    _validityTimer?.Dispose();
                    _validityTimer = null;
                    _state = MenuSessionState.Ended;
                    StateHasChanged();
                }
            });
        }, null, TimeSpan.FromSeconds(15), TimeSpan.FromSeconds(15));
    }

    private void SelectVariant(VarientModel variant)
    {
        _selectedVariant = variant;
    }

    private void OpenCart() => _cartOpen = !_cartOpen;

    private void AddToCart()
    {
        if (_item is null || _selectedVariant is null) return;

        CartService.AddItem(new CartItem
        {
            MenuItemId = _item.Id,
            ItemName = _item.ItemName,
            ImageUrl = _item.ImageUrl,
            VarientId = _selectedVariant.Id,
            VarientName = _selectedVariant.VarientName,
            UnitPrice = _selectedVariant.Price,
            Quantity = _quantity
        });

        Snackbar.Add($"{_item.ItemName} added to cart.", MudBlazor.Severity.Success);
        _quantity = 1;
        _selectedVariant = null;
    }

    private void OnOrderPlaced()
    {
        Navigation.NavigateTo($"/menu?t={TableToken}");
    }

    private string GetVariantStyle(bool isSelected)
    {
        var border = isSelected ? "var(--mud-palette-primary)" : "transparent";
        return $"cursor:pointer; border-radius:10px; border: 2px solid {border};";
    }

    public void Dispose()
    {
        CartService.OnCartChanged -= OnCartChanged;
        _waitTimer?.Dispose();
        _validityTimer?.Dispose();
    }
}