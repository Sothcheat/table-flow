@using TableFlow.Web.Models
@using TableFlow.Web.Services
@using MudBlazor.Services
@inject CartService CartService
@inject OrderApiService OrderApiService
@inject ISnackbar Snackbar
@inject IBrowserViewportService BrowserViewportService
@implements IBrowserViewportObserver
@implements IAsyncDisposable

<MudDrawer Open="Open"
           OpenChanged="OnOpenChanged"
           Anchor="@_anchor"
           Variant="DrawerVariant.Temporary"
           Width="380px"
           Height="@_drawerHeight"
           Elevation="4">

    <div style="display:flex; flex-direction:column; height:100%;">

        @* Header *@
        <div style="padding:16px 20px; display:flex; align-items:center; justify-content:space-between; border-bottom:1px solid var(--mud-palette-divider); flex-shrink:0;">
            <div style="display:flex; align-items:center; gap:10px;">
                <div style="width:36px;height:36px;border-radius:9px;background:rgba(13,107,99,0.1);display:flex;align-items:center;justify-content:center;">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Style="color:#0D6B63; font-size:1.2rem;" />
                </div>
                <div>
                    <MudText Typo="Typo.h5" Style="font-weight:700; line-height:1.1;">Your Cart</MudText>
                    <MudText Typo="Typo.caption" Style="color:#64748B;">@CartService.TotalCount item@(CartService.TotalCount == 1 ? "" : "s")</MudText>
                </div>
            </div>
            <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="CloseDrawer" />
        </div>

        @* Cart Items *@
        <div style="flex:1; overflow-y:auto; padding:16px 20px;">
            @if (!CartService.Items.Any())
            {
                <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:260px; gap:14px;">
                    <div style="width:72px;height:72px;border-radius:50%;background:#F1F5F9;display:flex;align-items:center;justify-content:center;">
                        <MudIcon Icon="@Icons.Material.Filled.ShoppingCartCheckout" Style="font-size:2.2rem; color:#CBD5E1;" />
                    </div>
                    <div style="text-align:center;">
                        <MudText Typo="Typo.body1" Style="font-weight:600; color:#334155;">Your cart is empty</MudText>
                        <MudText Typo="Typo.caption" Style="color:#94A3B8;">Add items from the menu to get started</MudText>
                    </div>
                </div>
            }
            else
            {
                @foreach (var item in CartService.Items)
                {
                    <MudPaper Elevation="0" Class="pa-3 mb-3"
                              Style="border-radius:12px; border:1px solid rgba(0,0,0,0.08);">
                        @* Top row: name + delete *@
                        <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:8px; margin-bottom:4px;">
                            <div style="flex:1; min-width:0;">
                                <MudText Typo="Typo.body1" Style="font-weight:600; color:#1E293B; line-height:1.3;">
                                    @item.ItemName
                                </MudText>
                                @if (!string.IsNullOrEmpty(item.VarientName))
                                {
                                    <span style="font-size:0.75rem; color:#6366F1; font-weight:500;">@item.VarientName</span>
                                }
                                @if (!string.IsNullOrEmpty(item.Note))
                                {
                                    <div style="display:flex; align-items:center; gap:3px; margin-top:2px;">
                                        <MudIcon Icon="@Icons.Material.Outlined.Notes" Style="font-size:0.85rem; color:#94A3B8;" />
                                        <span style="font-size:0.72rem; color:#94A3B8;">@item.Note</span>
                                    </div>
                                }
                            </div>
                            <MudIconButton Icon="@Icons.Material.Filled.Close"
                                           Size="Size.Small"
                                           Style="color:#94A3B8; margin-top:-4px; margin-right:-6px;"
                                           OnClick="@(() => CartService.RemoveItem(item.Key))" />
                        </div>

                        @* Bottom row: qty controls + subtotal *@
                        <div style="display:flex; align-items:center; justify-content:space-between; margin-top:10px;">
                            <div style="display:flex; align-items:center; gap:4px; background:#F8FAFC; border-radius:8px; padding:3px;">
                                <MudIconButton Icon="@Icons.Material.Filled.Remove"
                                               Size="Size.Small"
                                               Style="@(item.Quantity <= 1 ? "color:#CBD5E1;" : "color:#0D6B63;")"
                                               Disabled="@(item.Quantity <= 1)"
                                               OnClick="@(() => CartService.UpdateQuantity(item.Key, item.Quantity - 1))" />
                                <span style="font-size:0.9rem; font-weight:700; min-width:22px; text-align:center; color:#1E293B;">@item.Quantity</span>
                                <MudIconButton Icon="@Icons.Material.Filled.Add"
                                               Size="Size.Small"
                                               Style="color:#0D6B63;"
                                               OnClick="@(() => CartService.UpdateQuantity(item.Key, item.Quantity + 1))" />
                            </div>
                            <div style="text-align:right;">
                                <div style="font-size:1rem; font-weight:700; color:#0D6B63;">$@item.TotalPrice.ToString("0.00")</div>
                                <div style="font-size:0.7rem; color:#94A3B8;">$@item.UnitPrice.ToString("0.00") each</div>
                            </div>
                        </div>
                    </MudPaper>
                }
            }
        </div>

        @* Footer *@
        @if (CartService.Items.Any())
        {
            <div style="padding:16px 20px; border-top:1px solid var(--mud-palette-divider); flex-shrink:0;">
                <div style="display:flex; justify-content:space-between; align-items:center; background:#F8FAFC; border-radius:10px; padding:12px 16px; margin-bottom:12px;">
                    <MudText Typo="Typo.body1" Style="font-weight:600; color:#475569;">Order Total</MudText>
                    <MudText Typo="Typo.h5" Style="font-weight:700; color:#0D6B63;">
                        $@CartService.TotalAmount.ToString("0.00")
                    </MudText>
                </div>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           FullWidth="true"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.CheckCircle"
                           Disabled="_placing"
                           OnClick="PlaceOrderAsync">
                    @if (_placing)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                        <span>Placing Order…</span>
                    }
                    else
                    {
                        <span>Place Order</span>
                    }
                </MudButton>
                <MudButton Variant="Variant.Text"
                           Color="Color.Error"
                           FullWidth="true"
                           Class="mt-1"
                           OnClick="CartService.Clear">
                    Clear Cart
                </MudButton>
            </div>
        }

    </div>
</MudDrawer>

@code {
    [Parameter] public bool Open { get; set; }
    [Parameter] public EventCallback<bool> OpenChanged { get; set; }
    [Parameter] public int SessionId { get; set; }
    [Parameter] public EventCallback OnOrderPlaced { get; set; }

    // IBrowserViewportObserver required properties
    Guid IBrowserViewportObserver.Id { get; } = Guid.NewGuid();
    ResizeOptions IBrowserViewportObserver.ResizeOptions { get; } = new()
    {
        ReportRate = 250,
        NotifyOnBreakpointOnly = true
    };

    private bool _placing = false;
    private bool _disposed = false;
    private Anchor _anchor = Anchor.End;
    private string _drawerHeight = "100%";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            CartService.OnCartChanged += OnCartUpdated;
            await BrowserViewportService.SubscribeAsync(this, fireImmediately: true);
        }
    }

    // IBrowserViewportObserver callback
    async Task IBrowserViewportObserver.NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs args)
    {
        UpdateAnchor(args.Breakpoint);
        await InvokeAsync(StateHasChanged);
    }

    private void UpdateAnchor(Breakpoint breakpoint)
    {
        if (breakpoint == Breakpoint.Xs || breakpoint == Breakpoint.Sm)
        {
            _anchor = Anchor.Bottom;
            _drawerHeight = "85vh";
        }
        else
        {
            _anchor = Anchor.End;
            _drawerHeight = "100%";
        }
    }

    private async Task OnOpenChanged(bool value)
    {
        await OpenChanged.InvokeAsync(value);
    }

    private async Task CloseDrawer()
    {
        await OpenChanged.InvokeAsync(false);
    }

    private void OnCartUpdated()
    {
        if (_disposed) return;
        try
        {
            InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException)
        {
            CartService.OnCartChanged -= OnCartUpdated;
        }
    }

    private async Task PlaceOrderAsync()
    {
        if (!CartService.Items.Any()) return;
        _placing = true;

        var (success, order, error) = await OrderApiService.PlaceOrderAsync(
            SessionId,
            CartService.Items.ToList()
        );

        if (success)
        {
            Snackbar.Add($"Order {order!.OrderNumber} placed successfully!", MudBlazor.Severity.Success);
            CartService.Clear();
            await CloseDrawer();
            await OnOrderPlaced.InvokeAsync();
        }
        else
        {
            Snackbar.Add($"Failed to place order: {error}", MudBlazor.Severity.Error);
        }

        _placing = false;
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        CartService.OnCartChanged -= OnCartUpdated;
        await BrowserViewportService.UnsubscribeAsync(this);
    }
}