@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject IHttpClientFactory HttpClientFactory
@using Microsoft.AspNetCore.Identity
@using TableFlow.Api.Data.Entities
@using TableFlow.Web.Auth

<PageTitle>Login — TableFlow</PageTitle>

<MudPaper Elevation="4"
          Class="pa-8 rounded-lg"
          Style="width:100%;max-width:420px">

        @* Brand *@
        <div style="display:flex; flex-direction:column; align-items:center; margin-bottom:32px;">
            <div style="width:64px; height:64px; border-radius:16px; background:rgba(13,107,99,0.1); display:flex; align-items:center; justify-content:center; margin-bottom:16px;">
                <MudIcon Icon="@Icons.Material.Filled.Restaurant" Style="font-size:2rem; color:#0D6B63;" />
            </div>
            <MudText Typo="Typo.h2" Color="Color.Primary" Align="Align.Center" Style="font-weight:700; letter-spacing:0.04em;">
                TableFlow
            </MudText>
            <MudText Typo="Typo.body2" Align="Align.Center" Style="color:#64748B; margin-top:4px;">
                Restaurant Management System
            </MudText>
        </div>

        @* Server-level error (wrong password, DB error) *@
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <MudAlert Severity="MudBlazor.Severity.Error" Class="mb-4" Dense="true">
                @_errorMessage
            </MudAlert>
        }

        @* EditForm — Blazilla requires EditForm, not MudForm *@
        <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">

            @* This single line wires FluentValidation to all fields *@
            <FluentValidator />

            <MudTextField @bind-Value="_model.Email"
                          For="@(() => _model.Email)"
                          Label="Email"
                          Variant="Variant.Outlined"
                          InputType="InputType.Email"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Email"
                          Class="mb-6"
                          Disabled="_isLoading" />

            <MudTextField @bind-Value="_model.Password"
                          For="@(() => _model.Password)"
                          Label="Password"
                          Variant="Variant.Outlined"
                          InputType="_showPassword ? InputType.Text : InputType.Password"
                          Adornment="Adornment.End"
                          AdornmentIcon="@(_showPassword
                                                        ? Icons.Material.Filled.VisibilityOff
                                                    : Icons.Material.Filled.Visibility)"
                          OnAdornmentClick="() => _showPassword = !_showPassword"
                          Class="mb-8"
                          Disabled="_isLoading" />

            <MudButton ButtonType="ButtonType.Submit"
                       Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Size="Size.Large"
                       Disabled="_isLoading">
                @if (_isLoading)
                {
                    <MudProgressCircular Size="Size.Small"
                                         Indeterminate="true"
                                         Class="mr-2" />
                    <span>Signing in...</span>
                }
                else
                {
                    <span>Sign In</span>
                }
            </MudButton>

        </EditForm>

    </MudPaper>

@code {
    private LoginModel _model = new();
    private string _errorMessage = string.Empty;
    private bool _isLoading = false;
    private bool _showPassword = false;

    private async Task HandleLoginAsync()
    {
        _errorMessage = string.Empty;
        _isLoading = true;

        try
        {
            var httpClient = HttpClientFactory.CreateClient("TableFlowApi");
            var loginResponse = await httpClient.PostAsJsonAsync("/api/auth/login", new
            {
                Email = _model.Email.Trim(),
                Password = _model.Password
            });

            if (!loginResponse.IsSuccessStatusCode)
            {
                _errorMessage = "Invalid email or password.";
                return;
            }

            var data = await loginResponse.Content.ReadFromJsonAsync<LoginResponseModel>();

            var user = await UserManager.FindByEmailAsync(_model.Email.Trim());
            var provider = AuthStateProvider as CustomAuthStateProvider;
            if (provider is not null && user is not null)
                await provider.LoginAsync(user.Id, data!.Token);

            var roles = await UserManager.GetRolesAsync(user!);

            if (roles.Contains("Admin"))
                Navigation.NavigateTo("/admin", forceLoad: true);
            else if (roles.Contains("Cashier"))
                Navigation.NavigateTo("/cashier", forceLoad: true);
            else if (roles.Contains("Kitchen"))
                Navigation.NavigateTo("/kitchen", forceLoad: true);
            else
                Navigation.NavigateTo("/", forceLoad: true);
        }
        finally
        {
            _isLoading = false;
        }
    }
}