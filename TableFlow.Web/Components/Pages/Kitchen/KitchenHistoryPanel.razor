@using TableFlow.Web.Models
@using TableFlow.Web.Services
@inject OrderApiService OrderApiService
@inject ISnackbar Snackbar

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.body2" Color="Color.Secondary">
        @if (_totalCount == 0)
        {
            <span>No orders found</span>
        }
        else
        {
            var first = (_page - 1) * PageSize + 1;
            var last  = Math.Min(_page * PageSize, _totalCount);
            <span>Showing @first–@last of @_totalCount order@(_totalCount == 1 ? "" : "s")</span>
        }
    </MudText>
    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Refresh"
               OnClick="LoadHistoryAsync">
        Refresh
    </MudButton>
</MudStack>

@* ── Filters ──────────────────────────────────────────────────────────── *@
<MudPaper Elevation="0" Class="pa-4 mb-4" Style="border:1px solid var(--mud-palette-lines-default);">

    <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Class="mb-3" OverrideStyles="false">
        @foreach (var bucket in _timeBuckets)
        {
            <MudButton Variant="@(_selectedBucket == bucket ? Variant.Filled : Variant.Outlined)"
                       OnClick="@(() => SelectBucketAsync(bucket))">
                @bucket
            </MudButton>
        }
    </MudButtonGroup>

    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudNumericField @bind-Value="_tableFilter"
                             @bind-Value:after="ResetAndLoadAsync"
                             Label="Table number"
                             Min="0"
                             Clearable="true"
                             Immediate="true"
                             DebounceInterval="400" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_searchText"
                          @bind-Value:after="ResetAndLoadAsync"
                          Label="Search order #"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true"
                          DebounceInterval="400" />
        </MudItem>
    </MudGrid>

    @if (_tableFilter is not null || !string.IsNullOrWhiteSpace(_searchText))
    {
        <MudButton Variant="Variant.Text" Color="Color.Secondary" Class="mt-2"
                   OnClick="ClearFiltersAsync" StartIcon="@Icons.Material.Filled.Clear">
            Clear filters
        </MudButton>
    }
</MudPaper>

@if (_loading)
{
    <MudStack Spacing="2">
        @for (int i = 0; i < 5; i++)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="64px" Class="rounded" />
        }
    </MudStack>
}
else if (_sessions.Count == 0)
{
    <MudPaper Elevation="0" Class="pa-12 d-flex flex-column align-center justify-center"
              Style="border:1px solid var(--mud-palette-lines-default); min-height:200px;">
        <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Default" Style="font-size:2.5rem; opacity:0.5;" />
        <MudText Typo="Typo.h6" Class="mt-3" Color="Color.Secondary">
            @(HasActiveFilters ? "No orders match your filters" : "No order history yet")
        </MudText>
    </MudPaper>
}
else
{
    <MudExpansionPanels MultiExpansion="true" Elevation="0"
                        Style="border-radius:8px; border:1px solid rgba(0,0,0,0.09); overflow:hidden;">
        @foreach (var session in _sessions)
        {
            var hasReady = session.Orders.Any(o => o.OrderStatus == "Ready");
            var stripColor = hasReady ? "#22C55E" : "#0D6B63";

            <MudExpansionPanel @key="session.SessionId">
                <TitleContent>
                    <div style="display:flex; align-items:center; gap:16px; width:100%; padding:4px 8px 4px 0;">

                        @* Status strip *@
                        <div style="width:4px; height:44px; border-radius:4px; flex-shrink:0; background:@stripColor;"></div>

                        @* Table + session *@
                        <div style="min-width:140px; flex-shrink:0;">
                            <div style="font-weight:700; font-size:0.9rem; color:#0D6B63;">Table @session.TableNumber</div>
                            <div style="font-size:0.75rem; color:#475569; margin-top:2px;">Session #@session.SessionId</div>
                        </div>

                        @* First order time *@
                        <div style="flex:1;">
                            <div style="font-size:0.75rem; color:#475569;">
                                @session.FirstOrderAt.ToLocalTime().ToString("MMM d, h:mm tt")
                            </div>
                        </div>

                        @* Order count *@
                        <div style="font-size:0.8rem; color:#64748B; flex-shrink:0; padding-right:4px;">
                            @session.Orders.Count order@(session.Orders.Count == 1 ? "" : "s")
                        </div>
                    </div>
                </TitleContent>

                <ChildContent>
                    <MudDivider />
                    <div style="padding:16px;">
                        <MudStack Spacing="2">
                            @foreach (var order in session.Orders)
                            {
                                <MudPaper Elevation="0" Style="border-radius:8px; border:1px solid rgba(0,0,0,0.09);">

                                    @* Order header *@
                                    <div style="display:flex; align-items:center; justify-content:space-between; padding:10px 14px; background:#F8FAFC; border-radius:8px 8px 0 0; border-bottom:1px solid rgba(0,0,0,0.07);">
                                        <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
                                            <span style="font-size:0.875rem; font-weight:700; color:#1E293B;">@order.OrderNumber</span>
                                            <span style="font-size:0.62rem; font-weight:700; background:#0D6B63; color:white; border-radius:100px; padding:2px 7px; flex-shrink:0;">@order.StationName</span>
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="@GetStatusColor(order.OrderStatus)"
                                                     Variant="Variant.Filled"
                                                     Style="font-size:0.68rem; height:20px;">
                                                @order.OrderStatus
                                            </MudChip>
                                        </div>
                                        <span style="font-size:0.75rem; color:#475569; flex-shrink:0;">
                                            @order.CreatedAt.ToLocalTime().ToString("h:mm tt")
                                        </span>
                                    </div>

                                    @* Order items *@
                                    <div style="padding:8px 14px 0;">
                                        @foreach (var item in order.Items)
                                        {
                                            var dimmed = item.OrderItemStatus == "Unavailable" || item.OrderItemStatus == "Cancelled";
                                            <div style="display:flex; align-items:baseline; padding:6px 0; border-bottom:1px solid rgba(0,0,0,0.05);">
                                                <div style="flex:1; display:flex; align-items:center; gap:6px; flex-wrap:wrap;">
                                                    <span style="font-size:0.875rem; font-weight:500;
                                                                 color:@(dimmed ? "#94A3B8" : "#1E293B");
                                                                 text-decoration:@(dimmed ? "line-through" : "none");">
                                                        @item.ItemName
                                                    </span>
                                                    @if (!string.IsNullOrEmpty(item.VarientName))
                                                    {
                                                        <span style="font-size:0.75rem; color:#6366F1; font-weight:500;">@item.VarientName</span>
                                                    }
                                                    @if (item.OrderItemStatus == "Unavailable")
                                                    {
                                                        <span style="font-size:0.6rem; font-weight:700; background:#EF4444; color:white; border-radius:100px; padding:1px 6px;">OUT</span>
                                                    }
                                                    else if (item.OrderItemStatus == "Cancelled")
                                                    {
                                                        <span style="font-size:0.6rem; font-weight:700; background:#94A3B8; color:white; border-radius:100px; padding:1px 6px;">VOID</span>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(item.Note))
                                                    {
                                                        <span style="display:flex; align-items:center; gap:3px; font-size:0.72rem; font-weight:600; color:#D97706;">
                                                            <MudIcon Icon="@Icons.Material.Outlined.Notes" Style="font-size:0.8rem; color:#D97706;" />@item.Note
                                                        </span>
                                                    }
                                                </div>
                                                <div style="font-size:0.8rem; color:#475569; width:36px; text-align:center; font-weight:600; flex-shrink:0;">×@item.Quantity</div>
                                                <div style="font-size:0.8rem; color:#475569; width:60px; text-align:right; flex-shrink:0;">$@item.UnitPrice.ToString("0.00")</div>
                                                <div style="font-size:0.875rem; font-weight:700; width:68px; text-align:right; flex-shrink:0;
                                                            color:@(dimmed ? "#94A3B8" : "#0D6B63");">
                                                    $@item.TotalPrice.ToString("0.00")
                                                </div>
                                            </div>
                                        }
                                    </div>

                                    @* Note *@
                                    @if (!string.IsNullOrWhiteSpace(order.Note))
                                    {
                                        <div style="padding:8px 14px;">
                                            <MudAlert Severity="MudBlazor.Severity.Info" Dense="true" Variant="Variant.Outlined">
                                                @order.Note
                                            </MudAlert>
                                        </div>
                                    }

                                    @* Order footer *@
                                    <div style="display:flex; justify-content:flex-end; align-items:center; padding:8px 14px; background:#F8FAFC; border-radius:0 0 8px 8px; border-top:1px solid rgba(0,0,0,0.05); gap:8px;">
                                        <span style="font-size:0.78rem; color:#475569;">Order total</span>
                                        <span style="font-size:1rem; font-weight:700; color:#1E293B;">$@order.OrderTotal.ToString("0.00")</span>
                                    </div>
                                </MudPaper>
                            }
                        </MudStack>
                    </div>
                </ChildContent>
            </MudExpansionPanel>
        }
    </MudExpansionPanels>

    @if (_totalPages > 1)
    {
        <div style="display:flex; justify-content:center; margin-top:24px;">
            <MudPagination Count="_totalPages"
                           Selected="_page"
                           SelectedChanged="OnPageChangedAsync"
                           ShowFirstButton="true"
                           ShowLastButton="true" />
        </div>
    }
}

@code {
    private class SessionGroup
    {
        public int SessionId { get; set; }
        public int TableNumber { get; set; }
        public DateTime FirstOrderAt { get; set; }
        public List<OrderModel> Orders { get; set; } = new();
    }

    private const int PageSize = 50;

    private List<SessionGroup> _sessions = new();
    private bool _loading = true;

    private int _totalCount = 0;
    private int _totalPages = 1;
    private int _page = 1;

    private readonly string[] _timeBuckets = { "Today", "Yesterday", "This Week", "This Month", "All Time" };
    private string _selectedBucket = "Today";

    private int? _tableFilter;
    private string _searchText = "";

    private bool HasActiveFilters =>
        _tableFilter is not null || !string.IsNullOrWhiteSpace(_searchText) || _selectedBucket != "Today";

    protected override async Task OnInitializedAsync()
    {
        await LoadHistoryAsync();
    }

    public async Task LoadHistoryAsync()
    {
        _loading = true;
        StateHasChanged();

        var (from, to) = GetBucketRange(_selectedBucket);
        var (success, result, errorDetail) = await OrderApiService.GetKitchenHistoryPagedAsync(
            from, to, _tableFilter, _searchText, _page, PageSize);

        if (!success)
        {
            Snackbar.Add($"Couldn't load order history ({errorDetail}). Try refreshing or logging in again.", MudBlazor.Severity.Error);
            _sessions = new();
            _totalCount = 0;
            _totalPages = 1;
            _loading = false;
            return;
        }

        _totalCount = result!.TotalCount;
        _totalPages = result.TotalPages;

        _sessions = result.Orders
            .GroupBy(o => o.SessionId)
            .Select(g => new SessionGroup
            {
                SessionId    = g.Key,
                TableNumber  = g.First().TableNumber,
                FirstOrderAt = g.Min(o => o.CreatedAt),
                Orders       = g.OrderBy(o => o.CreatedAt).ToList()
            })
            .OrderByDescending(s => s.Orders.Max(o => o.CreatedAt))
            .ToList();

        _loading = false;
    }

    private async Task SelectBucketAsync(string bucket)
    {
        _selectedBucket = bucket;
        await ResetAndLoadAsync();
    }

    private async Task ResetAndLoadAsync()
    {
        _page = 1;
        await LoadHistoryAsync();
    }

    private async Task ClearFiltersAsync()
    {
        _tableFilter = null;
        _searchText = "";
        await ResetAndLoadAsync();
    }

    private async Task OnPageChangedAsync(int page)
    {
        _page = page;
        await LoadHistoryAsync();
    }

    private static (DateTimeOffset? From, DateTimeOffset? To) GetBucketRange(string bucket)
    {
        var today = DateTime.Today;
        return bucket switch
        {
            "Today"      => (new DateTimeOffset(today), new DateTimeOffset(today.AddDays(1))),
            "Yesterday"  => (new DateTimeOffset(today.AddDays(-1)), new DateTimeOffset(today)),
            "This Week"  => (new DateTimeOffset(today.AddDays(-(int)((7 + today.DayOfWeek - DayOfWeek.Monday) % 7))), new DateTimeOffset(today.AddDays(1))),
            "This Month" => (new DateTimeOffset(new DateTime(today.Year, today.Month, 1)), new DateTimeOffset(today.AddDays(1))),
            "All Time"   => (null, null),
            _            => (new DateTimeOffset(today), new DateTimeOffset(today.AddDays(1)))
        };
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Pending"   => Color.Warning,
        "Preparing" => Color.Info,
        "Ready"     => Color.Success,
        "Served"    => Color.Default,
        _           => Color.Default
    };
}
