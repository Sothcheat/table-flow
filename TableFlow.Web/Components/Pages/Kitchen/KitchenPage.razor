@page "/kitchen"
@layout KitchenLayout
@attribute [Authorize(Roles = "Kitchen")]
@using TableFlow.Web.Models
@using TableFlow.Web.Services
@inject OrderApiService OrderApiService
@inject AppUpdateService AppUpdates
@inject ISnackbar Snackbar
@implements IDisposable

<style>
    @@keyframes urgency-bounce {
        0%, 100% { transform: translateY(0);    animation-timing-function: cubic-bezier(0.8, 0, 1, 1); }
        50%      { transform: translateY(-7px); animation-timing-function: cubic-bezier(0, 0, 0.2, 1); }
    }
    .order-urgent { animation: urgency-bounce 1.4s infinite; }
</style>
<PageTitle>Kitchen — TableFlow</PageTitle>

<MudText Typo="Typo.h2" Class="mb-4" Style="font-weight:700;">Kitchen</MudText>

<MudTabs Rounded="true" ApplyEffectsToContainer="true" PanelClass="pt-4"
         @bind-ActivePanelIndex="_activeTab"
         @bind-ActivePanelIndex:after="OnTabChanged">

    @* ── Queue tab ───────────────────────────────────────────────────── *@
    <MudTabPanel Text="Queue" Icon="@Icons.Material.Filled.Restaurant" BadgeData="@(_orders.Count > 0 ? _orders.Count.ToString() : null)" BadgeColor="Color.Warning">

        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4" Wrap="Wrap.Wrap">
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-4">
                @(FilteredOrders.Count) active order@(FilteredOrders.Count == 1 ? "" : "s")
            </MudText>
            @if (DistinctStations.Count > 1)
            {
                <MudChipSet T="string" SelectionMode="SelectionMode.SingleSelection"
                            SelectedValue="_stationFilter"
                            SelectedValueChanged="@((string v) => _stationFilter = v ?? "All")"
                            Class="mt-2">
                    <MudChip T="string" Value="@("All")" Color="Color.Default" Variant="Variant.Outlined">All</MudChip>
                    @foreach (var station in DistinctStations)
                    {
                        <MudChip T="string" Value="@station" Color="Color.Primary" Variant="Variant.Outlined">@station</MudChip>
                    }
                </MudChipSet>
            }
        </MudStack>

        @if (_loading)
        {
            <MudGrid>
                @for (int i = 0; i < 6; i++)
                {
                    <MudItem xs="12" sm="12" md="6" lg="4">
                        <MudPaper Elevation="0" Class="pa-5" Style="border:1px solid var(--mud-palette-lines-default);">
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="60%" Height="32px" />
                            <MudSkeleton SkeletonType="SkeletonType.Text" Width="40%" />
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="90px" Class="mt-2" />
                            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="44px" Class="mt-3" />
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
        else if (_orders.Count == 0)
        {
            <MudPaper Elevation="0" Class="pa-12 d-flex flex-column align-center justify-center" Style="border:1px solid var(--mud-palette-lines-default); min-height:300px;">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size:3rem;" />
                <MudText Typo="Typo.h6" Class="mt-3" Color="Color.Secondary">No active orders right now</MudText>
            </MudPaper>
        }
        else
        {
            <MudGrid>
                @foreach (var order in FilteredOrders)
                {
                    <MudItem xs="12" sm="6" md="4" Style="align-self:start">
                        <MudPaper Elevation="0" Class="@GetCardClass(order.CreatedAt)"
                                  Style="@GetCardStyle(order.CreatedAt)">

                            @* ── Header ──────────────────────────────────────────── *@
                            <div style="padding:18px 20px 12px;">
                                <div style="display:flex; justify-content:space-between; align-items:flex-start; gap:8px; margin-bottom:6px;">
                                    <div>
                                        <div style="font-size:1.4rem; font-weight:800; line-height:1.15; color:#0F172A;">
                                            Table @order.TableNumber
                                        </div>
                                        <div style="display:flex; align-items:center; gap:6px; margin-top:2px;">
                                            <span style="font-size:0.72rem; font-weight:500; color:#94A3B8; letter-spacing:0.03em;">
                                                @order.OrderNumber
                                            </span>
                                            <span style="font-size:0.62rem; font-weight:700; background:#0D6B63; color:white; border-radius:100px; padding:2px 7px; flex-shrink:0;">
                                                @order.StationName
                                            </span>
                                        </div>
                                    </div>
                                    <MudChip T="string" Color="@GetStatusColor(order.OrderStatus)" Size="Size.Small"
                                             Style="font-weight:700; font-size:0.72rem;">
                                        @order.OrderStatus
                                    </MudChip>
                                </div>

                                @* Urgency timer *@
                                <div style="display:flex; align-items:center; gap:4px;">
                                    <MudIcon Icon="@Icons.Material.Filled.Schedule"
                                             Style="@($"font-size:0.82rem; color:{GetUrgencyColor(order.CreatedAt)};")" />
                                    <span style="@($"font-size:0.78rem; font-weight:700; color:{GetUrgencyColor(order.CreatedAt)};")">
                                        @GetRelativeTime(order.CreatedAt)
                                    </span>
                                </div>
                            </div>

                            <MudDivider />

                            @* ── Items ───────────────────────────────────────────── *@
                            <div style="padding:14px 20px;">
                                @foreach (var item in order.Items)
                                {
                                    var unavailable = item.OrderItemStatus == "Unavailable";
                                    <div style="display:flex; align-items:center; justify-content:space-between; padding:4px 0;">
                                        <div style="display:flex; align-items:baseline; gap:10px; flex:1; min-width:0;">
                                            <span style="font-size:0.9rem; font-weight:800; min-width:26px; color:@(unavailable ? "#EF4444" : "#0D6B63");">
                                                @item.Quantity×
                                            </span>
                                            <span style="font-size:0.95rem; font-weight:500; color:@(unavailable ? "#EF4444" : "#1E293B"); text-decoration:@(unavailable ? "line-through" : "none");">
                                                @item.ItemName@(item.VarientName is not null ? $" ({item.VarientName})" : "")
                                            </span>
                                            @if (unavailable)
                                            {
                                                <span style="font-size:0.62rem; font-weight:700; background:#EF4444; color:white; border-radius:100px; padding:2px 7px; flex-shrink:0;">OUT</span>
                                            }
                                        </div>
                                        @if (!unavailable && item.OrderItemStatus != "Done")
                                        {
                                            <MudIconButton Icon="@Icons.Material.Filled.RemoveCircleOutline"
                                                           Size="Size.Small"
                                                           Style="color:#94A3B8; padding:2px; flex-shrink:0;"
                                                           Title="Mark unavailable"
                                                           Disabled="@_updatingItemIds.Contains(item.Id)"
                                                           OnClick="@(() => MarkItemUnavailableAsync(item, order))" />
                                        }
                                    </div>
                                }
                            </div>

                            @* ── Note ────────────────────────────────────────────── *@
                            @if (!string.IsNullOrWhiteSpace(order.Note))
                            {
                                <div style="padding:0 20px 14px;">
                                    <MudAlert Severity="MudBlazor.Severity.Info" Dense="true" Variant="Variant.Outlined">
                                        @order.Note
                                    </MudAlert>
                                </div>
                            }

                            @* ── Action ──────────────────────────────────────────── *@
                            <div style="padding:4px 20px 18px;">
                                @if (order.OrderStatus == "Ready")
                                {
                                    <MudAlert Severity="MudBlazor.Severity.Success" Variant="Variant.Outlined"
                                              Icon="@Icons.Material.Filled.RoomService">
                                        <span style="font-weight:600;">Waiting for pickup</span>
                                    </MudAlert>
                                }
                                else
                                {
                                    <MudButton Variant="Variant.Filled"
                                               Color="@GetActionColor(order.OrderStatus)"
                                               FullWidth="true"
                                               Size="Size.Large"
                                               Style="font-size:0.95rem; font-weight:700; letter-spacing:0.02em;"
                                               Disabled="@_updatingOrderIds.Contains(order.Id)"
                                               OnClick="@(() => AdvanceStatusAsync(order))">
                                        @if (_updatingOrderIds.Contains(order.Id))
                                        {
                                            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                        }
                                        @GetActionLabel(order.OrderStatus)
                                    </MudButton>
                                }
                            </div>
                        </MudPaper>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudTabPanel>

    @* ── History tab — lazy-mounted on first click ────────────────────── *@
    <MudTabPanel Text="History" Icon="@Icons.Material.Filled.History">
        @if (_historyActivated)
        {
            <KitchenHistoryPanel @ref="_historyPanel" />
        }
    </MudTabPanel>

</MudTabs>

@code {
    private List<OrderModel> _orders = new();
    private bool _loading = true;
    private readonly HashSet<int> _updatingOrderIds = new();
    private readonly HashSet<int> _updatingItemIds = new();

    private int _activeTab = 0;
    private bool _historyActivated = false;
    private KitchenHistoryPanel? _historyPanel;

    private string _stationFilter = "All";
    private System.Timers.Timer? _clockTimer;

    private List<OrderModel> FilteredOrders =>
        _stationFilter == "All" ? _orders : _orders.Where(o => o.StationName == _stationFilter).ToList();

    private List<string> DistinctStations =>
        _orders.Select(o => o.StationName).Distinct().OrderBy(s => s).ToList();

    protected override async Task OnInitializedAsync()
    {
        AppUpdates.OrdersUpdated += OnOrdersUpdated;
        await LoadOrdersAsync();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        if (!firstRender) return;
        _clockTimer = new System.Timers.Timer(30_000);
        _clockTimer.Elapsed += async (_, _) => await InvokeAsync(StateHasChanged);
        _clockTimer.AutoReset = true;
        _clockTimer.Start();
    }

    private void OnOrdersUpdated(int sessionId)
    {
        // Kitchen shows all active orders — any change in any session needs a refresh
        try
        {
            InvokeAsync(async () =>
            {
                await LoadOrdersAsync();
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException) { AppUpdates.OrdersUpdated -= OnOrdersUpdated; }
    }

    private void OnTabChanged()
    {
        if (_activeTab == 1) _historyActivated = true;
    }

    private bool _hasLoadedOnce = false;

    private async Task LoadOrdersAsync()
    {
        var (success, orders) = await OrderApiService.GetKitchenOrdersCheckedAsync();

        if (!success)
        {
            if (_hasLoadedOnce)
                Snackbar.Add("Couldn't refresh orders — check your connection or login.", MudBlazor.Severity.Error);
            _loading = false;
            return;
        }

        // Most urgent tier first (red→amber→green), oldest within each tier
        _orders = orders
            .OrderBy(o => GetUrgencyLevel(o.CreatedAt))
            .ThenBy(o => o.CreatedAt)
            .ToList();
        _loading = false;
        _hasLoadedOnce = true;
    }

    private async Task AdvanceStatusAsync(OrderModel order)
    {
        var nextStatus = GetNextStatus(order.OrderStatus);
        _updatingOrderIds.Add(order.Id);
        StateHasChanged();

        var success = await OrderApiService.UpdateOrderStatusAsync(order.Id, nextStatus);

        _updatingOrderIds.Remove(order.Id);

        if (success)
        {
            await LoadOrdersAsync();
            Snackbar.Add($"{order.OrderNumber} moved to {nextStatus}", MudBlazor.Severity.Success);
        }
        else
        {
            Snackbar.Add($"Couldn't update {order.OrderNumber}. Please try again.", MudBlazor.Severity.Error);
        }

        StateHasChanged();
    }

    private async Task MarkItemUnavailableAsync(OrderItemModel item, OrderModel order)
    {
        _updatingItemIds.Add(item.Id);
        StateHasChanged();
        var success = await OrderApiService.UpdateOrderItemStatusAsync(item.Id, "Unavailable");
        _updatingItemIds.Remove(item.Id);
        if (success)
        {
            item.OrderItemStatus = "Unavailable";
            Snackbar.Add($"{item.ItemName} marked unavailable — menu updated.", MudBlazor.Severity.Warning);
        }
        else
        {
            Snackbar.Add("Failed to mark item unavailable.", MudBlazor.Severity.Error);
        }
        StateHasChanged();
    }

    private static string GetNextStatus(string current) => current switch
    {
        "Pending"   => "Preparing",
        "Preparing" => "Ready",
        _           => current
    };

    private static string GetActionLabel(string current) => current switch
    {
        "Pending"   => "Start Preparing",
        "Preparing" => "Mark Ready",
        _           => ""
    };

    private static Color GetStatusColor(string status) => status switch
    {
        "Pending"   => Color.Warning,
        "Preparing" => Color.Info,
        "Ready"     => Color.Success,
        _           => Color.Default
    };

    private static Color GetActionColor(string status) => status switch
    {
        "Pending"   => Color.Primary,
        "Preparing" => Color.Success,
        _           => Color.Default
    };

    private static string GetCardClass(DateTime createdAt) =>
        GetUrgencyLevel(createdAt) == 0 ? "d-flex flex-column order-urgent" : "d-flex flex-column";

    private static string GetCardStyle(DateTime createdAt)
    {
        var base_ = $"border:1px solid var(--mud-palette-lines-default); border-top:4px solid {GetUrgencyColor(createdAt)}; overflow:hidden;";
        return GetUrgencyLevel(createdAt) == 0 ? base_ + " background:#FFF8F8;" : base_;
    }

    // 0 = red/urgent (>10 min), 1 = amber/warning (5-10 min), 2 = green/fresh (<5 min)
    private static int GetUrgencyLevel(DateTime createdAt)
    {
        var m = (DateTime.UtcNow - createdAt.ToUniversalTime()).TotalMinutes;
        return m >= 10 ? 0 : m >= 5 ? 1 : 2;
    }

    private static string GetUrgencyColor(DateTime createdAt) => GetUrgencyLevel(createdAt) switch
    {
        0 => "#EF4444",
        1 => "#F59E0B",
        _ => "#22C55E"
    };

    private static string GetRelativeTime(DateTime createdAt)
    {
        var diff = DateTime.UtcNow - createdAt.ToUniversalTime();
        if (diff.TotalSeconds < 60) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes} min{((int)diff.TotalMinutes == 1 ? "" : "s")} ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours} hr{((int)diff.TotalHours == 1 ? "" : "s")} ago";
        return createdAt.ToString("MMM d, h:mm tt");
    }

    public void Dispose()
    {
        _clockTimer?.Stop();
        _clockTimer?.Dispose();
        AppUpdates.OrdersUpdated -= OnOrdersUpdated;
    }
}
