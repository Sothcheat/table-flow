@page "/kitchen/history"
@layout MainLayout
@attribute [Authorize(Roles = "Kitchen")]
@using TableFlow.Web.Models
@using TableFlow.Web.Services
@inject OrderApiService OrderApiService
@inject ISnackbar Snackbar

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h4">Kitchen History</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @(TotalFilteredOrders) order@(TotalFilteredOrders == 1 ? "" : "s")
            across @(_filteredSessions.Count) session@(_filteredSessions.Count == 1 ? "" : "s")
        </MudText>
    </MudStack>
    <MudButton Variant="Variant.Outlined"
               Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Refresh"
               OnClick="LoadHistoryAsync">
        Refresh
    </MudButton>
</MudStack>

@* ── Filters ──────────────────────────────────────────────────────────── *@
<MudPaper Elevation="0" Class="pa-4 mb-4" Style="border:1px solid var(--mud-palette-lines-default);">

    @* Time bucket — single select, defaults to Today *@
    <MudButtonGroup Variant="Variant.Outlined" Color="Color.Primary" Class="mb-3" OverrideStyles="false">
        @foreach (var bucket in _timeBuckets)
        {
            <MudButton Variant="@(_selectedBucket == bucket ? Variant.Filled : Variant.Outlined)"
                       OnClick="@(() => SelectBucket(bucket))">
                @bucket
            </MudButton>
        }
    </MudButtonGroup>

    <MudGrid>
        <MudItem xs="12" sm="6">
            <MudNumericField @bind-Value="_tableFilter" @bind-Value:after="ApplyFilters" Label="Table number" Min="0" Clearable="true" />
        </MudItem>
        <MudItem xs="12" sm="6">
            <MudTextField @bind-Value="_searchText" @bind-Value:after="ApplyFilters" Label="Search order #" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" Immediate="true" />
        </MudItem>
    </MudGrid>

    @if (_tableFilter is not null || !string.IsNullOrWhiteSpace(_searchText))
    {
        <MudButton Variant="Variant.Text" Color="Color.Secondary" Class="mt-2" OnClick="ClearFilters" StartIcon="@Icons.Material.Filled.Clear">
            Clear filters
        </MudButton>
    }
</MudPaper>

@if (_loading)
{
    <MudPaper Elevation="0" Class="pa-4" Style="border:1px solid var(--mud-palette-lines-default);">
        @for (int i = 0; i < 4; i++)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="60px" Class="mb-3" />
        }
    </MudPaper>
}
else if (_filteredSessions.Count == 0)
{
    <MudPaper Elevation="0" Class="pa-12 d-flex flex-column align-center justify-center" Style="border:1px solid var(--mud-palette-lines-default); min-height:200px;">
        <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Default" Style="font-size:2.5rem; opacity:0.5;" />
        <MudText Typo="Typo.h6" Class="mt-3" Color="Color.Secondary">
            @(_allSessions.Count == 0 ? "No order history yet" : "No orders match your filters")
        </MudText>
    </MudPaper>
}
else
{
    @* ── Session groups, always expanded ──────────────────────────────── *@
    <MudStack Spacing="4">
        @foreach (var session in _filteredSessions)
        {
            <MudPaper Elevation="0" Style="border:1px solid var(--mud-palette-lines-default); overflow:hidden;">

                @* Session header *@
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center"
                          Class="pa-4" Style="background-color:var(--mud-palette-background);">
                    <MudStack Row="true" Spacing="3" AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.TableRestaurant" Color="Color.Primary" />
                        <MudText Typo="Typo.h6">Table @session.TableNumber</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Session #@session.SessionId</MudText>
                    </MudStack>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @session.Orders.Count order@(session.Orders.Count == 1 ? "" : "s")
                        &middot; first order @session.FirstOrderAt.ToLocalTime().ToString("MMM d, h:mm tt")
                    </MudText>
                </MudStack>

                <MudDivider />

                @* Orders within this session, always visible (no extra expand click) *@
                <MudTable Items="session.Orders" Hover="true" Dense="false" Elevation="0">
                    <HeaderContent>
                        <MudTh>Order #</MudTh>
                        <MudTh>Items</MudTh>
                        <MudTh>Received</MudTh>
                        <MudTh>Status</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate Context="order">
                        <MudTd>@order.OrderNumber</MudTd>
                        <MudTd>@GetCondensedItems(order)</MudTd>
                        <MudTd>@order.CreatedAt.ToLocalTime().ToString("h:mm tt")</MudTd>
                        <MudTd>
                            <MudChip T="string" Color="@GetStatusColor(order.OrderStatus)" Size="Size.Small">
                                @order.OrderStatus
                            </MudChip>
                        </MudTd>
                        <MudTd>
                            <MudIconButton Icon="@(_expandedIds.Contains(order.Id) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                           Size="Size.Small"
                                           OnClick="@(() => ToggleExpand(order.Id))" />
                        </MudTd>
                    </RowTemplate>
                    <ChildRowContent Context="order">
                        @if (_expandedIds.Contains(order.Id))
                        {
                            <MudTr>
                                <MudTd colspan="5" Class="pa-0">
                                    <MudPaper Elevation="0" Class="pa-4 ma-2" Style="background-color:var(--mud-palette-background); border:1px solid var(--mud-palette-lines-default);">
                                        <MudStack Spacing="1">
                                            @foreach (var item in order.Items)
                                            {
                                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                                    <MudText Typo="Typo.body2">
                                                        @item.Quantity &times; @item.ItemName@(item.VarientName is not null ? $" ({item.VarientName})" : "")
                                                    </MudText>
                                                    <MudText Typo="Typo.body2" Color="Color.Secondary">@item.TotalPrice.ToString("C")</MudText>
                                                </MudStack>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(order.Note))
                                            {
                                                <MudAlert Severity="MudBlazor.Severity.Info" Dense="true" Variant="Variant.Outlined" Class="mt-2">
                                                    @order.Note
                                                </MudAlert>
                                            }
                                        </MudStack>
                                    </MudPaper>
                                </MudTd>
                            </MudTr>
                        }
                    </ChildRowContent>
                </MudTable>
            </MudPaper>
        }
    </MudStack>
}

@code {
    // One group per session, holding all its orders together.
    private class SessionGroup
    {
        public int SessionId { get; set; }
        public int TableNumber { get; set; }
        public DateTime FirstOrderAt { get; set; }
        public List<OrderModel> Orders { get; set; } = new();
    }

    private List<SessionGroup> _allSessions = new();
    private List<SessionGroup> _filteredSessions = new();
    private bool _loading = true;
    private readonly HashSet<int> _expandedIds = new();

    private int TotalFilteredOrders => _filteredSessions.Sum(s => s.Orders.Count);

    private readonly string[] _timeBuckets = { "Today", "Yesterday", "This Week", "This Month", "All Time" };
    private string _selectedBucket = "Today";

    private int? _tableFilter;
    private string _searchText = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadHistoryAsync();
    }

    private async Task LoadHistoryAsync()
    {
        _loading = true;
        StateHasChanged();

        // GetKitchenHistoryOrdersCheckedAsync() takes no parameters and returns
        // everything the API considers "history" — all time-range filtering below
        // (Today, Yesterday, etc.) and grouping by session happens here on the client.
        var (success, orders, errorDetail) = await OrderApiService.GetKitchenHistoryOrdersCheckedAsync();

        if (!success)
        {
            Snackbar.Add($"Couldn't load order history ({errorDetail}). Try refreshing or logging in again.", MudBlazor.Severity.Error);
            _allSessions = new();
            _filteredSessions = new();
            _loading = false;
            return;
        }

        _allSessions = orders
            .GroupBy(o => o.SessionId)
            .Select(g => new SessionGroup
            {
                SessionId = g.Key,
                TableNumber = g.First().TableNumber,
                FirstOrderAt = g.Min(o => o.CreatedAt),
                Orders = g.OrderBy(o => o.CreatedAt).ToList()
            })
            // Most recently active session first
            .OrderByDescending(s => s.Orders.Max(o => o.CreatedAt))
            .ToList();

        ApplyFilters();
        _loading = false;
    }

    private void SelectBucket(string bucket)
    {
        _selectedBucket = bucket;
        ApplyFilters();
    }

    private void ApplyFilters()
    {
        var (rangeStart, rangeEnd) = GetBucketRange(_selectedBucket);

        var query = _allSessions.AsEnumerable();

        // Filter orders within each session to the selected time range first,
        // then drop sessions left with zero matching orders.
        var grouped = query.Select(s => new SessionGroup
        {
            SessionId = s.SessionId,
            TableNumber = s.TableNumber,
            FirstOrderAt = s.FirstOrderAt,
            Orders = s.Orders.Where(o =>
            {
                var local = o.CreatedAt.ToLocalTime();
                if (rangeStart is not null && local < rangeStart) return false;
                if (rangeEnd is not null && local >= rangeEnd) return false;
                if (_tableFilter is not null && o.TableNumber != _tableFilter.Value) return false;
                if (!string.IsNullOrWhiteSpace(_searchText) &&
                    !o.OrderNumber.Contains(_searchText, StringComparison.OrdinalIgnoreCase)) return false;
                return true;
            }).ToList()
        })
        .Where(s => s.Orders.Count > 0)
        .ToList();

        _filteredSessions = grouped;
    }

    // Maps a bucket name to a [start, end) local-time range. Null = no bound.
    private static (DateTime? Start, DateTime? End) GetBucketRange(string bucket)
    {
        var today = DateTime.Today;
        return bucket switch
        {
            "Today" => (today, today.AddDays(1)),
            "Yesterday" => (today.AddDays(-1), today),
            // Week starts Monday
            "This Week" => (today.AddDays(-(int)((7 + today.DayOfWeek - DayOfWeek.Monday) % 7)), today.AddDays(1)),
            "This Month" => (new DateTime(today.Year, today.Month, 1), today.AddDays(1)),
            "All Time" => (null, null),
            _ => (today, today.AddDays(1))
        };
    }

    private void ClearFilters()
    {
        _tableFilter = null;
        _searchText = "";
        ApplyFilters();
    }

    private void ToggleExpand(int orderId)
    {
        if (!_expandedIds.Add(orderId))
            _expandedIds.Remove(orderId);
    }

    private static string GetCondensedItems(OrderModel order)
    {
        if (order.Items.Count == 0) return "—";
        var first = order.Items.Take(2).Select(i => $"{i.Quantity}× {i.ItemName}");
        var summary = string.Join(", ", first);
        var remaining = order.Items.Count - 2;
        return remaining > 0 ? $"{summary} +{remaining} more" : summary;
    }

    private static Color GetStatusColor(string status) => status switch
    {
        "Pending" => Color.Warning,
        "Preparing" => Color.Info,
        "Ready" => Color.Success,
        "Served" => Color.Default,
        _ => Color.Default
    };
}
