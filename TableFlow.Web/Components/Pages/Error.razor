@page "/Error"
@layout LoginLayout
@using System.Diagnostics
@using TableFlow.Web.Components.Layout

<PageTitle>Something went wrong · TableFlow</PageTitle>

<div style="width:100%; max-width:440px; background:white; border-radius:16px; padding:40px 32px; text-align:center; box-shadow:0 20px 60px rgba(0,0,0,0.15);">

    <div style="width:68px; height:68px; border-radius:50%; background:#FEF2F2; display:flex; align-items:center; justify-content:center; margin:0 auto 20px;">
        <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Style="font-size:2.2rem; color:#EF4444;" />
    </div>

    <MudText Typo="Typo.h4" Style="font-weight:700; color:#1E293B; margin-bottom:8px;">
        Something went wrong
    </MudText>
    <MudText Typo="Typo.body2" Style="color:#64748B; margin-bottom:24px;">
        An unexpected error occurred. Please try again or return to the home page.
    </MudText>

    @if (ShowRequestId)
    {
        <div style="background:#F8FAFC; border-radius:8px; padding:10px 14px; margin-bottom:24px; text-align:left;">
            <span style="font-size:0.72rem; color:#94A3B8; font-weight:500;">Request ID</span>
            <div style="font-size:0.78rem; color:#475569; font-family:monospace; margin-top:2px; word-break:break-all;">@RequestId</div>
        </div>
    }

    <MudButton Href="/"
               Variant="Variant.Filled"
               Color="Color.Primary"
               FullWidth="true"
               Size="Size.Large"
               StartIcon="@Icons.Material.Filled.Home">
        Return to Home
    </MudButton>
</div>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
