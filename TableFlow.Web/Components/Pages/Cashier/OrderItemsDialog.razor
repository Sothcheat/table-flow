@using TableFlow.Web.Models
@using TableFlow.Web.Services
@inject OrderApiService OrderApiService
@inject AppUpdateService AppUpdates
@inject ISnackbar Snackbar
@implements IDisposable

<MudDialog>
    <TitleContent>
        <div style="display:flex; align-items:center; gap:10px;">
            <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Style="color:#0D6B63;" />
            <MudText Typo="Typo.h6" Style="font-weight:700;">Table @TableNumber — Orders</MudText>
            @if (_refreshing)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Style="color:#0D6B63;" />
            }
        </div>
    </TitleContent>
    <DialogContent>
        @if (_loading)
        {
            <MudStack Spacing="3">
                @for (int i = 0; i < 3; i++)
                {
                    <MudPaper Elevation="0" Style="border-radius:12px; border:1px solid rgba(0,0,0,0.08); overflow:hidden;">
                        <div style="padding:10px 14px; background:#F8FAFC;">
                            <MudSkeleton Width="60%" Height="18px" />
                        </div>
                        <div style="padding:8px 14px;">
                            <MudSkeleton Width="100%" Height="44px" Class="mb-2" />
                            <MudSkeleton Width="100%" Height="44px" />
                        </div>
                    </MudPaper>
                }
            </MudStack>
        }
        else if (_orders.Count == 0)
        {
            <div style="text-align:center; padding:40px 0;">
                <MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Style="font-size:3.5rem; color:#CBD5E1;" Class="mb-3" />
                <MudText Typo="Typo.body1" Style="color:#64748B; font-weight:500;">No orders for this table yet.</MudText>
            </div>
        }
        else
        {
            @foreach (var order in _orders)
            {
                <MudPaper Elevation="0" Class="mb-4"
                          Style="border-radius:12px; border:1px solid rgba(0,0,0,0.08); overflow:hidden;">
                    <div style="padding:10px 16px; background:#F8FAFC; display:flex; justify-content:space-between; align-items:center; gap:8px;">
                        <div>
                            <div style="display:flex; align-items:center; gap:6px;">
                                <MudText Typo="Typo.body1" Style="font-weight:700; color:#1E293B;">@order.OrderNumber</MudText>
                                <span style="font-size:0.62rem; font-weight:700; background:#0D6B63; color:white; border-radius:100px; padding:2px 7px; flex-shrink:0;">@order.StationName</span>
                            </div>
                            <MudText Typo="Typo.caption" Style="color:#64748B;">@order.CreatedAt.ToLocalTime().ToString("HH:mm")</MudText>
                        </div>
                        <span style="font-size:0.7rem; font-weight:700; background:@GetOrderStatusColor(order.OrderStatus); color:white; border-radius:100px; padding:3px 10px; white-space:nowrap;">
                            @order.OrderStatus
                        </span>
                    </div>
                    <MudDivider />
                    <div>
                        @foreach (var item in order.Items)
                        {
                            var (label, bg) = GetStatusDisplay(order.OrderStatus, item.OrderItemStatus);
                            <div style="display:flex; align-items:center; padding:10px 16px; border-bottom:1px solid rgba(0,0,0,0.04); gap:12px;">
                                <div style="flex:1; min-width:0;">
                                    <MudText Typo="Typo.body2" Style="font-weight:600; color:#1E293B;">@item.ItemName</MudText>
                                    @if (!string.IsNullOrEmpty(item.VarientName))
                                    {
                                        <MudText Typo="Typo.caption" Style="color:#6366F1;">@item.VarientName</MudText>
                                    }
                                    <MudText Typo="Typo.caption" Style="color:#64748B;">×@item.Quantity · $@item.TotalPrice.ToString("0.00")</MudText>
                                    @if (!string.IsNullOrWhiteSpace(item.Note))
                                    {
                                        <div style="display:flex; align-items:center; gap:3px; margin-top:2px;">
                                            <MudIcon Icon="@Icons.Material.Outlined.Notes" Style="font-size:0.8rem; color:#D97706;" />
                                            <span style="font-size:0.72rem; font-weight:600; color:#D97706;">@item.Note</span>
                                        </div>
                                    }
                                </div>
                                <div style="flex-shrink:0;">
                                    <span style="font-size:0.7rem; font-weight:700; background:@bg; color:white; border-radius:100px; padding:3px 10px; white-space:nowrap;">@label</span>
                                </div>
                            </div>
                        }
                    </div>
                </MudPaper>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => MudDialog.Cancel())">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public int SessionId { get; set; }
    [Parameter] public int TableNumber { get; set; }

    private List<OrderModel> _orders = [];
    private bool _loading = true;
    private bool _refreshing = false;

    protected override async Task OnInitializedAsync()
    {
        AppUpdates.OrdersUpdated += OnOrdersUpdated;
        await LoadOrdersAsync();
    }

    private void OnOrdersUpdated(int sessionId)
    {
        if (sessionId != -1 && sessionId != SessionId) return;
        try
        {
            InvokeAsync(async () =>
            {
                await LoadOrdersAsync(silent: true);
                StateHasChanged();
            });
        }
        catch (ObjectDisposedException) { AppUpdates.OrdersUpdated -= OnOrdersUpdated; }
    }

    private async Task LoadOrdersAsync(bool silent = false)
    {
        if (!silent) _loading = true;
        else _refreshing = true;
        _orders = await OrderApiService.GetSessionOrdersAsync(SessionId);
        _loading = false;
        _refreshing = false;
    }

    private static string GetOrderStatusColor(string status) => status switch
    {
        "Pending"   => "#F59E0B",
        "Preparing" => "#3B82F6",
        "Ready"     => "#22C55E",
        "Served"    => "#94A3B8",
        _           => "#94A3B8"
    };

    // Item status chips derive from order status so old data (Waiting items in a Ready order)
    // still shows correctly. Only Unavailable and Cancelled break out of this.
    private static (string Label, string Color) GetStatusDisplay(string orderStatus, string itemStatus)
    {
        if (itemStatus == "Unavailable") return ("Unavailable", "#EF4444");
        if (itemStatus == "Cancelled")   return ("Cancelled",   "#94A3B8");

        return orderStatus switch
        {
            "Pending"   => ("Pending",   "#94A3B8"),
            "Preparing" => ("Preparing", "#F59E0B"),
            "Ready"     => ("Ready",     "#22C55E"),
            "Served"    => ("Served",    "#0D6B63"),
            "Cancelled" => ("Cancelled", "#94A3B8"),
            _           => (itemStatus,  "#94A3B8")
        };
    }

    public void Dispose() => AppUpdates.OrdersUpdated -= OnOrdersUpdated;
}
