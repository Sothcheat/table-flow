@page "/cashier"
@using TableFlow.Web.Models
@using TableFlow.Web.Services
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "Cashier")]
@inject TableApiService TableApiService
@inject OrderApiService OrderApiService
@inject SessionApiService SessionApiService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthStateProvider
@implements IDisposable

<PageTitle>Cashier Dashboard — TableFlow</PageTitle>

<style>
    .table-card {
        transition: transform 0.18s ease, box-shadow 0.18s ease;
    }
    .table-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18) !important;
    }
    .table-card:active {
        transform: translateY(-2px);
        box-shadow: 0 6px 14px rgba(0, 0, 0, 0.14) !important;
    }
</style>

<MudText Typo="Typo.h2" Style="font-weight:700;" Class="mt-4 mb-6">Cashier Dashboard</MudText>

@* ── Ready for Pickup banner — only shows when kitchen has marked orders Ready ── *@
@if (_readyOrders.Any())
{
    <MudPaper Elevation="3" Class="pa-4 mb-6"
              Style="border-radius:12px; border-left:6px solid #22C55E; background:#F0FDF4;">
        <div style="display:flex; align-items:center; justify-content:space-between; cursor:pointer;"
             @onclick="@(() => _bannerExpanded = !_bannerExpanded)">
            <div style="display:flex; align-items:center; gap:8px;">
                <MudIcon Icon="@Icons.Material.Filled.RoomService" Style="color:#15803D; font-size:1.5rem;" />
                <MudText Typo="Typo.h6" Style="font-weight:700; color:#15803D;">
                    Ready for Pickup (@_readyOrders.Count)
                </MudText>
            </div>
            <MudIcon Icon="@(_bannerExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                     Style="color:#15803D;" />
        </div>
        @if (_bannerExpanded)
        {
            <div style="margin-top:12px; max-height:220px; overflow-y:auto; display:flex; flex-direction:column; gap:8px;">
                @foreach (var order in _readyOrders)
                {
                    <div style="display:flex; justify-content:space-between; align-items:center; background:white; padding:10px 14px; border-radius:8px;">
                        <div>
                            <MudText Typo="Typo.body1" Style="font-weight:600;">@order.OrderNumber</MudText>
                            <MudText Typo="Typo.caption" Style="color:#64748B;">Table @order.TableNumber</MudText>
                        </div>
                        <MudChip T="string" Color="Color.Success" Size="Size.Small" Style="font-weight:700;">
                            At the pass
                        </MudChip>
                    </div>
                }
            </div>
        }
    </MudPaper>
}

@* ── Unavailable items warning banner ── *@
@if (_unavailableOrders.Any())
{
    <MudPaper Elevation="3" Class="pa-4 mb-6"
              Style="border-radius:12px; border-left:6px solid #F59E0B; background:#FFFBEB;">
        <div style="display:flex; align-items:center; justify-content:space-between; cursor:pointer;"
             @onclick="@(() => _unavailableBannerExpanded = !_unavailableBannerExpanded)">
            <div style="display:flex; align-items:center; gap:8px;">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Style="color:#B45309; font-size:1.5rem;" />
                <MudText Typo="Typo.h6" Style="font-weight:700; color:#B45309;">
                    Unavailable Items (@_unavailableOrders.Count order@(_unavailableOrders.Count == 1 ? "" : "s") affected)
                </MudText>
            </div>
            <MudIcon Icon="@(_unavailableBannerExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                     Style="color:#B45309;" />
        </div>
        @if (_unavailableBannerExpanded)
        {
            <div style="margin-top:12px; max-height:220px; overflow-y:auto; display:flex; flex-direction:column; gap:8px;">
                @foreach (var order in _unavailableOrders)
                {
                    <div style="background:white; padding:10px 14px; border-radius:8px;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:4px;">
                            <MudText Typo="Typo.body1" Style="font-weight:600;">@order.OrderNumber</MudText>
                            <MudText Typo="Typo.caption" Style="color:#64748B;">Table @order.TableNumber</MudText>
                        </div>
                        @foreach (var item in order.Items.Where(i => i.OrderItemStatus == "Unavailable"))
                        {
                            <div style="display:flex; align-items:center; gap:6px;">
                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Style="color:#EF4444; font-size:0.9rem;" />
                                <MudText Typo="Typo.body2" Style="color:#EF4444; font-weight:500;">
                                    @item.ItemName@(item.VarientName is not null ? $" ({item.VarientName})" : "") ×@item.Quantity
                                </MudText>
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </MudPaper>
}

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Class="mb-4" />
}
else
{
    @* Stats Row *@
    <MudGrid Class="mb-6">
        @* Table status cards — tinted backgrounds so they stand out *@
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center"
                      Style="background:#EFF6FF; border-radius:10px;">
                <MudText Typo="Typo.h3" Style="font-weight:700; color:#1E40AF;">@_tables.Count</MudText>
                <MudText Typo="Typo.body2" Style="color:#475569; font-weight:500;">Total Tables</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center"
                      Style="background:#F0FDF4; border-radius:10px;">
                <MudText Typo="Typo.h3" Style="font-weight:700; color:#15803D;">
                    @_tables.Count(t => t.Status == "Available")
                </MudText>
                <MudText Typo="Typo.body2" Style="color:#475569; font-weight:500;">Available</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center"
                      Style="background:#FFFBEB; border-radius:10px;">
                <MudText Typo="Typo.h3" Style="font-weight:700; color:#B45309;">
                    @_tables.Count(t => t.Status == "Occupied")
                </MudText>
                <MudText Typo="Typo.body2" Style="color:#475569; font-weight:500;">Occupied</MudText>
            </MudPaper>
        </MudItem>

        @* Personal shift stats — solid filled hero cards *@
        <MudItem xs="6">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center"
                      Style="background:#0D6B63; border-radius:10px;">
                <MudText Typo="Typo.h3" Style="font-weight:700; color:white;">
                    $@(_myStats?.TodayRevenue.ToString("0.00") ?? "—")
                </MudText>
                <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.8); font-weight:500;">My Revenue Today</MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="6">
            <MudPaper Elevation="2" Class="pa-4 d-flex flex-column align-center"
                      Style="background:#4F46E5; border-radius:10px;">
                <MudText Typo="Typo.h3" Style="font-weight:700; color:white;">
                    @(_myStats?.TodayClosedSessions.ToString() ?? "—")
                </MudText>
                <MudText Typo="Typo.body2" Style="color:rgba(255,255,255,0.8); font-weight:500;">Sessions Closed Today</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* Header row with last-refresh timestamp *@
    <div style="display:flex; justify-content:space-between; align-items:center;" class="mt-8 mb-4">
        <MudText Typo="Typo.h3" Style="font-weight:600;">Tables</MudText>
        <MudText Typo="Typo.body1" Style="font-weight:600;" Color="Color.Secondary">
            Updated @_lastRefreshed.ToString("HH:mm")
        </MudText>
    </div>

    <MudGrid>
        @foreach (var table in _tables)
        {
            <MudItem xs="6" sm="4" md="3">
                @if (table.Status == "Available")
                {
                    <MudPaper Elevation="2"
                              Class="pa-4 d-flex flex-column align-center justify-center table-card"
                              Style="background:#22C55E; cursor:pointer; min-height:130px; border-radius:12px;"
                              @onclick="@(() => ToggleStatus(table))">
                        <MudIcon Icon="@Icons.Material.Filled.TableRestaurant"
                                 Style="font-size:2rem; color:white;" Class="mb-1" />
                        <MudText Typo="Typo.h6" Style="color:white; font-weight:700;">
                            Table @table.TableNumber
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.85);">
                            Tap to open
                        </MudText>
                    </MudPaper>
                }
                else
                {
                    <MudPaper Elevation="2"
                              Class="pa-4 d-flex flex-column align-center justify-center table-card"
                              Style="background:#F59E0B; cursor:pointer; min-height:130px; border-radius:12px; position:relative;"
                              @onclick="@(() => ToggleStatus(table))">

                        @* Action buttons — stopPropagation keeps them from triggering the close flow *@
                        <div style="position:absolute; top:8px; right:8px; display:flex; gap:4px;"
                             @onclick:stopPropagation="true">
                            <MudIconButton Icon="@Icons.Material.Filled.ReceiptLong"
                                           Size="Size.Small"
                                           Style="background:rgba(255,255,255,0.25); color:white;"
                                           Title="View orders"
                                           OnClick="@(() => ShowOrdersAsync(table))" />
                            <MudIconButton Icon="@Icons.Material.Filled.QrCode2"
                                           Size="Size.Small"
                                           Style="background:rgba(255,255,255,0.25); color:white;"
                                           Title="Show QR code"
                                           OnClick="@(() => ShowQrCodeAsync(table))" />
                        </div>

                        <MudIcon Icon="@Icons.Material.Filled.TableRestaurant"
                                 Style="font-size:2rem; color:white;" Class="mb-1" />
                        <MudText Typo="Typo.h6" Style="color:white; font-weight:700;">
                            Table @table.TableNumber
                        </MudText>
                        <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.9);">
                            @if (_activeSessions.TryGetValue(table.Id, out var s) && s.CreatedById != _currentUserId)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size:0.75rem; vertical-align:middle;" />
                                <span> @s.CreatedByName</span>
                            }
                            else
                            {
                                <span>Occupied</span>
                            }
                        </MudText>
                        @if (_activeSessions.TryGetValue(table.Id, out var session))
                        {
                            <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.85); margin-top:2px;">
                                @GetElapsed(session.OpenedAt)
                            </MudText>
                        }
                    </MudPaper>
                }
            </MudItem>
        }
    </MudGrid>
}

@code {
    private List<TableModel> _tables = [];
    private Dictionary<int, SessionModel> _activeSessions = new();
    private CashierStatsModel? _myStats;
    private List<OrderModel> _readyOrders = new();
    private bool _bannerExpanded = true;
    private List<OrderModel> _unavailableOrders = new();
    private bool _unavailableBannerExpanded = true;
    private bool _loading = true;
    private DateTime _lastRefreshed = DateTime.Now;
    private System.Threading.Timer? _refreshTimer;
    private string _currentUserId = "";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _currentUserId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
        await LoadTablesAsync();

        // Silent auto-refresh every 30 seconds
        _refreshTimer = new System.Threading.Timer(async _ =>
        {
            await InvokeAsync(async () =>
            {
                await LoadTablesAsync(showLoader: false);
                StateHasChanged();
            });
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task LoadTablesAsync(bool showLoader = true)
    {
        if (showLoader) _loading = true;

        // Fetch tables, stats, ready orders, and unavailable alerts in parallel
        var tablesTask = TableApiService.GetTablesAsync();
        var statsTask = SessionApiService.GetMyStatsAsync();
        var readyTask = OrderApiService.GetReadyOrdersAsync();
        var unavailableTask = OrderApiService.GetUnavailableAlertOrdersAsync();
        await Task.WhenAll(tablesTask, statsTask, readyTask, unavailableTask);
        _tables = tablesTask.Result;
        _myStats = statsTask.Result;
        _readyOrders = readyTask.Result;
        _unavailableOrders = unavailableTask.Result;

        // Pre-fetch active sessions for occupied tables in parallel
        var occupied = _tables.Where(t => t.Status == "Occupied").ToList();
        _activeSessions = new Dictionary<int, SessionModel>();
        if (occupied.Any())
        {
            var pairs = await Task.WhenAll(occupied.Select(async t =>
            {
                var s = await SessionApiService.GetActiveSessionAsync(t.Id);
                return (TableId: t.Id, Session: s);
            }));
            foreach (var p in pairs)
            {
                if (p.Session is not null)
                    _activeSessions[p.TableId] = p.Session;
            }
        }

        _lastRefreshed = DateTime.Now;
        if (showLoader) _loading = false;
    }

    private async Task ToggleStatus(TableModel table)
    {
        if (table.Status == "Available")
        {
            var (success, _, error) = await SessionApiService.OpenSessionAsync(table.Id);
            if (!success)
            {
                Snackbar.Add($"Failed to open session: {error}", MudBlazor.Severity.Error);
                return;
            }

            await LoadTablesAsync();
            Snackbar.Add($"Table {table.TableNumber} session opened.", MudBlazor.Severity.Success);
            // No QR pop-up here — the static QR sticker lives on the table.
            // Cashier can re-show/print it via the QR button if a sticker is missing.
        }
        else
        {
            // Use cached active session to skip a redundant API call
            if (!_activeSessions.TryGetValue(table.Id, out var activeSession))
            {
                var fetched = await SessionApiService.GetActiveSessionAsync(table.Id);
                if (fetched is null)
                {
                    Snackbar.Add("No active session found for this table.", MudBlazor.Severity.Warning);
                    return;
                }
                activeSession = fetched;
            }

            // Check whether any orders exist — determines which flow to show
            var orders = await OrderApiService.GetSessionOrdersAsync(activeSession.Id);

            if (!orders.Any())
            {
                // No orders yet — any cashier can void this (wrong table, customer switched, etc.)
                var confirmed = await DialogService.ShowMessageBoxAsync(
                    "No Orders Placed",
                    $"Table {table.TableNumber} has no orders. Cancel this session and free the table?",
                    yesText: "Yes, Cancel Session",
                    cancelText: "Keep Open");

                if (confirmed is not true) return;

                var (cancelOk, cancelError) = await SessionApiService.CancelSessionAsync(activeSession.Id);
                if (cancelOk)
                {
                    await LoadTablesAsync();
                    Snackbar.Add($"Table {table.TableNumber} session cancelled.", MudBlazor.Severity.Success);
                }
                else
                {
                    Snackbar.Add($"Failed to cancel session: {cancelError}", MudBlazor.Severity.Error);
                }
                return;
            }

            // Has orders — only the opener can close (payment flow)
            if (activeSession.CreatedById != _currentUserId)
            {
                Snackbar.Add($"Session opened by {activeSession.CreatedByName}. Only they can close it.", MudBlazor.Severity.Warning);
                return;
            }

            var parameters = new DialogParameters
            {
                { nameof(CloseSessionDialog.SessionId), activeSession.Id },
                { nameof(CloseSessionDialog.TableNumber), table.TableNumber }
            };
            var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small, FullWidth = true };
            var dialog = await DialogService.ShowAsync<CloseSessionDialog>("Close Session", parameters, options);
            var result = await dialog.Result;
            if (result is { Canceled: false })
                await LoadTablesAsync();
        }
    }

    private async Task ShowOrdersAsync(TableModel table)
    {
        if (!_activeSessions.TryGetValue(table.Id, out var session))
        {
            session = await SessionApiService.GetActiveSessionAsync(table.Id);
            if (session is null)
            {
                Snackbar.Add("No active session found.", MudBlazor.Severity.Warning);
                return;
            }
        }

        var parameters = new DialogParameters
        {
            { nameof(OrderItemsDialog.SessionId), session.Id },
            { nameof(OrderItemsDialog.TableNumber), table.TableNumber }
        };
        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseButton = true
        };
        await DialogService.ShowAsync<OrderItemsDialog>("", parameters, options);
    }

    private async Task ShowQrCodeAsync(TableModel table)
    {
        // The QR is static per-table — fetch it by table id (not tied to a session).
        var qr = await TableApiService.GetTableQrAsync(table.Id);
        if (qr is null || string.IsNullOrEmpty(qr.QrCodeBase64))
        {
            Snackbar.Add("QR code unavailable for this table.", MudBlazor.Severity.Warning);
            return;
        }

        var parameters = new DialogParameters
        {
            { nameof(QrCodeDialog.QrCodeBase64), qr.QrCodeBase64 },
            { nameof(QrCodeDialog.TableNumber), table.TableNumber }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.ExtraSmall, FullWidth = true };
        await DialogService.ShowAsync<QrCodeDialog>("", parameters, options);
    }

    private static string GetElapsed(DateTime openedAt)
    {
        var elapsed = DateTime.Now - openedAt.ToLocalTime();
        if (elapsed.TotalMinutes < 1) return "Just opened";
        if (elapsed.TotalMinutes < 60) return $"{(int)elapsed.TotalMinutes} min";
        return $"{(int)elapsed.TotalHours}h {elapsed.Minutes}m";
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
    }
}
