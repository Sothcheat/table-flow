@page "/admin/users"
@attribute [Authorize(Roles = "Admin")]
@inject UserApiService UserApi
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@using Microsoft.AspNetCore.Authorization
@using TableFlow.Web.Models
@using TableFlow.Web.Services

<PageTitle>Staff Management — TableFlow</PageTitle>
<MudButton StartIcon="@Icons.Material.Filled.ArrowBack"
           Variant="Variant.Text"
           Color="Color.Primary"
           Class="mb-4"
           OnClick="@(() => Navigation.NavigateTo("/admin"))">
    Back to Dashboard
</MudButton>
<MudText Typo="Typo.h2" Class="mb-1" Style="font-weight:700;">Staff Management</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">
    @_users.Count staff member@(_users.Count == 1 ? "" : "s")
</MudText>

@* Toolbar *@
<MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-4">
    <MudTextField @bind-Value="_search"
                  Immediate="true"
                  Placeholder="Search by name, email or role…"
                  Adornment="Adornment.Start"
                  AdornmentIcon="@Icons.Material.Filled.Search"
                  Variant="Variant.Outlined"
                  Margin="Margin.Dense"
                  Clearable="true"
                  Style="flex:1;" />
    <MudButton Color="Color.Primary"
               Variant="Variant.Filled"
               StartIcon="@Icons.Material.Filled.PersonAdd"
               OnClick="OpenAddDialog">
        Add Staff
    </MudButton>
</MudStack>

@* Table *@
@if (_loading)
{
    <MudStack Spacing="3">
        @for (int i = 0; i < 4; i++)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="52px" Class="rounded" />
        }
    </MudStack>
}
else if (_users.Count == 0)
{
    <MudPaper Elevation="0" Style="border-radius:8px; border:1px solid rgba(0,0,0,0.09);" Class="pa-10 d-flex flex-column align-center">
        <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Secondary" Size="Size.Large" Class="mb-2" />
        <MudText Typo="Typo.body1" Color="Color.Secondary">No staff accounts yet. Click Add Staff to create one.</MudText>
    </MudPaper>
}
else
{
    @if (_filteredUsers.Count() == 0)
    {
        <MudPaper Elevation="0" Style="border-radius:8px; border:1px solid rgba(0,0,0,0.09);" Class="pa-10 d-flex flex-column align-center">
            <MudIcon Icon="@Icons.Material.Filled.SearchOff" Color="Color.Secondary" Size="Size.Large" Class="mb-2" />
            <MudText Typo="Typo.body1" Color="Color.Secondary">No staff match your search.</MudText>
        </MudPaper>
    }
    else
    {
        <MudTable Items="_filteredUsers" Hover="true" Striped="true" Elevation="0"
                  Style="border-radius:8px; border:1px solid rgba(0,0,0,0.09); overflow:hidden;">
            <HeaderContent>
                <MudTh Style="font-weight:600;">Name</MudTh>
                <MudTh Style="font-weight:600;">Email</MudTh>
                <MudTh Style="text-align:center; font-weight:600;">Role</MudTh>
                <MudTh Style="text-align:center; font-weight:600;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.FullName</MudTd>
                <MudTd DataLabel="Email" Style="color:#475569;">@context.Email</MudTd>
                <MudTd DataLabel="Role" Style="text-align:center">
                    <MudChip T="string"
                             Color="@(context.Role == "Cashier" ? Color.Primary : Color.Secondary)"
                             Size="Size.Small">
                        @context.Role
                    </MudChip>
                </MudTd>
                <MudTd Style="text-align:center">
                    <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                   Size="Size.Small"
                                   Color="Color.Primary"
                                   OnClick="@(() => OpenEditDialog(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                   Size="Size.Small"
                                   Color="Color.Error"
                                   OnClick="@(() => DeleteUser(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    }
}

@code {
    private List<StaffUserModel> _users = new();
    private bool _loading = true;
    private string _search = string.Empty;

    private IEnumerable<StaffUserModel> _filteredUsers =>
        string.IsNullOrWhiteSpace(_search)
            ? _users
            : _users.Where(u =>
                u.FullName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                u.Email.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
                u.Role.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loading = true;
        try
        {
            _users = await UserApi.GetUsersAsync();
        }
        catch
        {
            Snackbar.Add("Failed to load staff list.", MudBlazor.Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OpenAddDialog()
    {
        var model = new UserFormModel();
        var parameters = new DialogParameters
        {
            { nameof(UserFormDialog.Model), model },
            { nameof(UserFormDialog.IsEditMode), false }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<UserFormDialog>("Add Staff", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: UserFormModel formData })
        {
            var success = await UserApi.CreateUserAsync(new CreateUserModel
            {
                FullName = formData.FullName,
                Email = formData.Email,
                Password = formData.Password,
                Role = formData.Role
            });

            if (success)
            {
                Snackbar.Add("Staff member created.", MudBlazor.Severity.Success);
                await LoadUsers();
            }
            else
            {
                Snackbar.Add("Failed to create staff member.", MudBlazor.Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(StaffUserModel user)
    {
        var model = new UserFormModel
        {
            FullName = user.FullName,
            Email = user.Email,
            Role = user.Role,
            IsEditMode = true
        };

        var parameters = new DialogParameters
        {
            { nameof(UserFormDialog.Model), model },
            { nameof(UserFormDialog.IsEditMode), true }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<UserFormDialog>("Edit Staff", parameters, options);
        var result = await dialog.Result;

        if (result is { Canceled: false, Data: UserFormModel formData })
        {
            var success = await UserApi.UpdateUserAsync(user.Id, new UpdateUserModel
            {
                FullName = formData.FullName,
                Email = formData.Email,
                Role = formData.Role,
                NewPassword = formData.NewPassword
            });

            if (success)
            {
                Snackbar.Add("Staff member updated.", MudBlazor.Severity.Success);
                await LoadUsers();
            }
            else
            {
                Snackbar.Add("Failed to update staff member.", MudBlazor.Severity.Error);
            }
        }
    }

    private async Task DeleteUser(StaffUserModel user)
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            "Delete Staff",
            $"Are you sure you want to delete {user.FullName}?",
            yesText: "Delete",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            var success = await UserApi.DeleteUserAsync(user.Id);
            if (success)
            {
                Snackbar.Add("Staff member deleted.", MudBlazor.Severity.Success);
                await LoadUsers();
            }
            else
            {
                Snackbar.Add("Failed to delete staff member.", MudBlazor.Severity.Error);
            }
        }
    }
}
