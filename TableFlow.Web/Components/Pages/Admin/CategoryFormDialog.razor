@inject MenuApiService MenuService
@inject ISnackbar Snackbar
@using TableFlow.Web.Models
@using TableFlow.Web.Services

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h3" Style="font-weight:700;" Class="pt-2">
            @Title
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudGrid>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.CategoryName"
                              Label="Category Name"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Error="@(_errors.ContainsKey("CategoryName"))"
                              ErrorText="@(_errors.GetValueOrDefault("CategoryName"))" />
            </MudItem>
            <MudItem xs="12">
                <MudNumericField @bind-Value="_form.DisplayOrder"
                                 Label="Display Order"
                                 Variant="Variant.Outlined"
                                 FullWidth="true"
                                 Min="0"
                                 Error="@(_errors.ContainsKey("DisplayOrder"))"
                                 ErrorText="@(_errors.GetValueOrDefault("DisplayOrder"))" />
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudItem Class="mb-2 mr-4">
            <MudButton OnClick="Cancel" Class="mr-3">Cancel</MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SubmitAsync"
                       Disabled="_saving">
                @(_saving ? "Saving..." : "Save")
            </MudButton>
        </MudItem>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public CategoryModel? Category { get; set; }  // null = Add, not null = Edit
    [Parameter] public int NextDisplayOrder { get; set; } = 1;
    [Parameter] public string Title { get; set; } = "Category";

    private CategoryFormModel _form = new();
    private Dictionary<string, string> _errors = new();
    private bool _saving = false;

    protected override void OnInitialized()
    {
        if (Category is not null)
        {
            _form.CategoryName = Category.CategoryName;
            _form.DisplayOrder = Category.DisplayOrder;
        } else
        {
            _form.DisplayOrder = NextDisplayOrder;
        }
    }

    private bool Validate()
    {
        _errors.Clear();
        if (string.IsNullOrWhiteSpace(_form.CategoryName))
            _errors["CategoryName"] = "Category name is required.";
        if (_form.DisplayOrder < 0)
            _errors["DisplayOrder"] = "Display order must be 0 or greater.";
        return _errors.Count == 0;
    }

    private async Task SubmitAsync()
    {
        if (!Validate()) return;
        _saving = true;

        if (Category is null)
        {
            var result = await MenuService.CreateCategoryAsync(_form);
            if (result is not null)
            {
                Snackbar.Add("Category created.", MudBlazor.Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Failed to create category.", MudBlazor.Severity.Error);
            }
        }
        else
        {
            var result = await MenuService.UpdateCategoryAsync(Category.Id, _form);
            if (result is not null)
            {
                Snackbar.Add("Category updated.", MudBlazor.Severity.Success);
                MudDialog.Close(DialogResult.Ok(true));
            }
            else
            {
                Snackbar.Add("Failed to update category.", MudBlazor.Severity.Error);
            }
        }

        _saving = false;
    }

    private void Cancel() => MudDialog.Cancel();
}