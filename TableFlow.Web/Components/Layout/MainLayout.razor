@inherits LayoutComponentBase
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject TableFlow.Web.Services.UnauthorizedNotifier UnauthorizedNotifier
@implements IDisposable
@using TableFlow.Web.Auth

<MudThemeProvider Theme="@TableFlowTheme.Theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    @* App bar — hides brand+hamburger on small screens *@
    <MudAppBar Elevation="1" Color="Color.Primary" Fixed="true">
        @* Hamburger — only on medium and up (desktop) *@
        <MudHidden Breakpoint="Breakpoint.Xs">
            <MudIconButton Icon="@Icons.Material.Filled.Menu"
                           Color="Color.Inherit"
                           Edge="Edge.Start"
                           OnClick="ToggleDrawer" />
        </MudHidden>
        @* Brand — only on medium and up (desktop) *@
        <MudHidden Breakpoint="Breakpoint.Xs">
            <MudText Typo="Typo.h3" Class="ml-2">TableFlow</MudText>
        </MudHidden>
        <MudSpacer />
        <MudText Typo="Typo.body2" Class="mr-3">@_userName</MudText>
        <MudIconButton Icon="@Icons.Material.Filled.Logout"
                       Color="Color.Inherit"
                       OnClick="LogoutAsync" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               Elevation="1"
               Variant="@DrawerVariant.Responsive"
               Class="tableflow-drawer"
               ClipMode="DrawerClipMode.Always" Overlay="false">

        @* Drawer header — only on small screens *@
        <MudHidden Breakpoint="Breakpoint.SmAndUp">
            <MudDrawerHeader Class="d-flex align-center pa-2">
                <MudIconButton Icon="@Icons.Material.Filled.Menu"
                               Color="Color.Inherit"
                               OnClick="ToggleDrawer" />
                <MudText Typo="Typo.h3" Color="Color.Inherit" Class="ml-2">
                    TableFlow
                </MudText>
            </MudDrawerHeader>
        </MudHidden>

        <MudNavMenu Class="mt-4">
            <AuthorizeView Roles="Admin">
                <MudNavLink Href="/admin"
                            Icon="@Icons.Material.Filled.AdminPanelSettings"
                            Match="NavLinkMatch.All">
                    Admin Dashboard
                </MudNavLink>
                <MudNavLink Href="/admin/sessions"
                            Icon="@Icons.Material.Filled.ReceiptLong"
                            Match="NavLinkMatch.Prefix">
                    Session History
                </MudNavLink>
                <MudNavLink Href="/admin/users"
                            Icon="@Icons.Material.Filled.People"
                            Match="NavLinkMatch.Prefix">
                    Staff Management
                </MudNavLink>
                <MudNavLink Href="/admin/menu"
                            Icon="@Icons.Material.Filled.RestaurantMenu"
                            Match="NavLinkMatch.Prefix">
                    Menu Management
                </MudNavLink>
                <MudNavLink Href="/admin/tables" Icon="@Icons.Material.Filled.TableRestaurant" Match="NavLinkMatch.Prefix">
                    Tables
                </MudNavLink>
            </AuthorizeView>

            <AuthorizeView Roles="Cashier">
                <MudNavLink Href="/cashier"
                            Icon="@Icons.Material.Filled.PointOfSale"
                            Match="NavLinkMatch.All">
                    Cashier Dashboard
                </MudNavLink>
                <MudNavLink Href="/admin/tables"
                            Icon="@Icons.Material.Filled.TableRestaurant"
                            Match="NavLinkMatch.Prefix">
                    Tables
                </MudNavLink>
            </AuthorizeView>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private string _userName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated == true)
        {
            _userName = user.Identity.Name ?? string.Empty;
        }

        UnauthorizedNotifier.OnUnauthorized += HandleUnauthorizedAsync;
    }

    private async Task HandleUnauthorizedAsync()
    {
        var provider = AuthStateProvider as CustomAuthStateProvider;
        if (provider is not null)
            await provider.LogoutAsync();

        await InvokeAsync(() => Navigation.NavigateTo("/login", forceLoad: false));
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task LogoutAsync()
    {
        var provider = AuthStateProvider as CustomAuthStateProvider;
        if (provider is not null)
            await provider.LogoutAsync();

        Navigation.NavigateTo("/login", forceLoad: false);
    }

    public void Dispose()
    {
        UnauthorizedNotifier.OnUnauthorized -= HandleUnauthorizedAsync;
    }
}